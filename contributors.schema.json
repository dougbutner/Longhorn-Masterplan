{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Longhorn Masterplan Contributors",
  "type": "object",
  "properties": {
    "contributors": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["color", "vaulta"],
        "properties": {
          "color":  { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
          "github": { "type": "string" },
          "vaulta": { "type": "string" },
          "role":   { "type": "string" }
        }
      }
    }
  },
  "required": ["contributors"]
}
